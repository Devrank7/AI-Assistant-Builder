{
  "clientId": "aguy_client",
  "apiEndpoint": "/api/chat",
  "streamEndpoint": "/api/chat/stream",
  "feedbackEndpoint": "/api/feedback",
  "leadsEndpoint": "/api/leads",
  "theme": {
    "primary": "#10B981",
    "accent": "#34D399",
    "background": "#ECFDF5"
  },
  "design": {
    "style": "glass",
    "position": "bottom-right",
    "size": "medium",
    "buttonShape": "circle",
    "darkMode": "light-only"
  },
  "bot": {
    "name": "AI-ассистент Аня",
    "avatar": "🤖",
    "greeting": "Привет, я виртуальный помощник Аня. Чем могу помочь?",
    "tone": "formal-friendly"
  },
  "features": {
    "streaming": true,
    "streamingSpeed": "fast",
    "quickReplies": true,
    "quickRepliesStyle": "pill",
    "contextualReplies": false,
    "feedback": true,
    "feedbackType": "thumbs",
    "feedbackThankYou": true,
    "leadCollection": true,
    "leadCollectionTrigger": "after-n-messages",
    "leadCollectionMessages": 3,
    "leadFields": ["name", "email"],
    "leadDestination": ["database"],
    "fileUpload": false,
    "imageDisplay": false,
    "markdown": true,
    "markdownLevel": "basic",
    "sound": false,
    "typingIndicator": true,
    "persistHistory": true,
    "clearHistory": true,
    "clearHistoryPosition": "header",
    "welcomeScreen": false,
    "unreadBadge": false,
    "autoOpen": false,
    "poweredBy": false,
    "language": "en"
  },
  "quickRepliesData": [
    {
      "text": "📋 How to book a service?",
      "icon": "📋"
    },
    {
      "text": "💰 What are your prices?",
      "icon": "💰"
    },
    {
      "text": "📞 Contacts",
      "icon": "📞"
    }
  ],
  "integrations": {
    "crm": null,
    "calendar": null,
    "payment": null,
    "webhook": null,
    "email": null,
    "telegram": false,
    "whatsapp": false
  },
  "ai": {
    "maxTokens": 1024,
    "temperature": 0.7,
    "topicRestriction": null,
    "blockedTopics": []
  }
}
